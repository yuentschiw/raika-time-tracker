{
  "manifest_version": 3,
  "name": "Raika Time Tracker",
  "version": "4.0.0",
  "description": "\u8ffd\u8e2a\u5f53\u524d\u805a\u7126\u7a97\u53e3\u7684\u9875\u9762\u505c\u7559\u65f6\u95f4\uff0c\u4e0a\u62a5\u7ed9 Raika",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "idle",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.jsonbin.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Raika Time Tracker"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}